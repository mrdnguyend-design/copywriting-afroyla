# Gmail IMAP Configuration
# Hướng dẫn tạo App Password:
# 1. Vào https://myaccount.google.com/security
# 2. Bật 2-Step Verification (nếu chưa bật)
# 3. Vào App Passwords → tạo password cho "Mail"
# 4. Copy 16-ký tự password vào đây (không có dấu cách)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here

# Klaviyo API
KLAVIYO_API_KEY=pk_your_klaviyo_api_key_here

# Postscript Login
PS_EMAIL=your-email@example.com
PS_PASSWORD=your-password-here
